# ─── Docker Build Context Exclusions ─────────────────────────────────────────
# Files and directories listed here are excluded from the Docker build context.
# This speeds up builds and prevents sensitive files from reaching the daemon.
# ─────────────────────────────────────────────────────────────────────────────

# Git
.git
.gitignore

# Dependencies (reinstalled inside the container during build)
node_modules

# Next.js build output (rebuilt inside the container)
.next
out

# Nginx config (not needed in the Next.js image; mounted into the Nginx container)
nginx

# Environment files — secrets must NEVER be baked into the image
.env
.env.*
!.env.example
!.env.dev.example

# Editor and OS files
.DS_Store
*.pem
.vscode
.idea

# Documentation
*.md
README*

# TypeScript build info
*.tsbuildinfo

logs/
