# ─── Production Environment Variables ────────────────────────────────────────
# Copy this file to .env and fill in real values on the Debian server:
#   cp .env.example .env
#   nano .env
#
# .env is git-ignored. This file (.env.example) is safe to commit.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# ── NextAuth ──────────────────────────────────────────────────────────────────
# NEXTAUTH_URL must match the public URL users access the app from.
NEXTAUTH_URL=https://your-domain.com

# Generate a strong secret with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-strong-random-secret

# ── Backend API (uncomment and set when backend is ready) ─────────────────────
# NEXT_PUBLIC_API_BASE_URL=https://api.your-domain.com
API_URL=https://umis-sb.babcock.edu.ng
