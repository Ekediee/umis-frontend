# ─── Development Environment Variables ───────────────────────────────────────
# Copy this file to .env.dev and fill in your values:
#   cp .env.dev.example .env.dev
#
# .env.dev is git-ignored. This file (.env.dev.example) is safe to commit.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOSTNAME=0.0.0.0

# ── HMR / File-watching (required for Docker volume mounts) ──────────────────
WATCHPACK_POLLING=true
CHOKIDAR_USEPOLLING=true

# ── NextAuth ──────────────────────────────────────────────────────────────────
# In development, NEXTAUTH_URL must match the address you open in your browser.
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=dev-secret-replace-in-production

# ── Backend API (uncomment and set when backend is ready) ─────────────────────
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
